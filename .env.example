# ============================================================
# AI Spend Audit — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.
# ============================================================

# Supabase (Database & Auth)
# Get these from https://supabase.com after creating a project
# Instructions: Project Settings → API → Copy the URL and keys
NEXT_PUBLIC_SUPABASE_URL=https://waljptefuiautfuhehyf.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Email Service (Resend - Transactional Emails)
# Get API key from https://resend.com
# Used to send audit confirmation emails with Resend
RESEND_API_KEY=re_your-api-key

# Application Settings
# Base URL for email links and redirects
# Use http://localhost:3000 for development
# Use your production domain for production (e.g., https://spend-lab.com)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Analytics (PostHog) - Optional
# Get from https://posthog.com for event tracking
NEXT_PUBLIC_POSTHOG_KEY=phc_your-key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ============================================================
# Setup Instructions
# ============================================================
#
# 1. Supabase Setup:
#    a) Create account at https://supabase.com
#    b) Create new project
#    c) Run migrations:
#       - supabase/migrations/001_initial_schema.sql
#       - supabase/migrations/002_leads_schema.sql
#       - supabase/migrations/003_audit_tracking_and_referrals.sql
#    d) Copy URL and API keys to this file
#
# 2. Resend Setup:
#    a) Create account at https://resend.com
#    b) Generate API key
#    c) Add to RESEND_API_KEY
#
# 3. Deployment:
#    - Copy this file to .env.local locally
#    - For production, set environment variables in your hosting provider
#    - Render: Project Settings → Environment → Add variables
#    - Vercel: Settings → Environment Variables → Add variables
#
# ============================================================

